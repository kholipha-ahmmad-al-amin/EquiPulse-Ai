{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "hosting": {
        "site": "equipulse-ai",
        "public": "dist",
        "cleanUrls": true,
        "trailingSlash": false,
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**",
                "headers": [
                    {"key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains"},
                    {"key": "X-Frame-Options", "value": "SAMEORIGIN"},
                    {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},
                    {"key": "Permissions-Policy", "value": "camera=(), geolocation=(), microphone=(self)"},
                    {"key": "X-Content-Type-Options", "value": "nosniff"},
                    {"key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups"}
                ]
            },
            {
                "source": "**/*.@(js|mjs|css|woff|woff2)",
                "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
            },
            {
                "source": "/",
                "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
            },
            {
                "source": "/@(pos|data|inventory|metrics|leaderboard|queue|profile|market|staff|controls|auth|home|faq)",
                "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
            },
            {
                "source": "/@(index.html|robots.txt|sitemap.xml|llms.txt|site.webmanifest|browserconfig.xml|sw.js|workbox-*.js)",
                "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
            },
            {
                "source": "**/*.xml",
                "headers": [{"key": "Content-Type", "value": "application/xml; charset=utf-8"}]
            },
            {
                "source": "**/*.txt",
                "headers": [{"key": "Content-Type", "value": "text/plain; charset=utf-8"}]
            },
            {
                "source": "/site.webmanifest",
                "headers": [{"key": "Content-Type", "value": "application/manifest+json; charset=utf-8"}]
            }
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}
