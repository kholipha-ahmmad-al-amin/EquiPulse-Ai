{
  "name": "equipulse",
  "description": "EquiPulse POS: The Ultimate Offline-First Enterprise Resource Planning & Point of Sale System for the Modern Cooperative Ecosystem.",
  "keywords": [
    "react",
    "pos",
    "erp",
    "offline-first",
    "pwa",
    "ai",
    "gemini",
    "duckdb",
    "firebase"
  ],
  "author": "EquiPulse Engineering Team",
  "license": "MIT",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "prebuild": "npm run assets:brand",
    "build": "tsc -b && vite build",
    "prebuild:prod": "npm run assets:brand",
    "build:prod": "tsc -b && vite build --mode production",
    "prebuild:smepulse": "npm run assets:brand && node scripts/generate-sitemap.mjs",
    "build:smepulse": "tsc -b && vite build --mode production --outDir dist --emptyOutDir",
    "deploy:smepulse": "npm run build:smepulse && firebase use equipulse-ai && firebase deploy --only hosting",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:report": "playwright show-report",
    "seo:index": "node --env-file=.env scripts/indexnow.mjs",
    "cf:purge": "node --env-file=.env scripts/cloudflare-purge.mjs",
    "deploy:prod": "npm run build && firebase deploy --only hosting && npm run cf:purge && npm run seo:index"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@google/genai": "^2.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "apache-arrow": "^21.1.0",
    "canvas-confetti": "^1.9.4",
    "cmdk": "^1.1.1",
    "driver.js": "^1.5.0",
    "firebase": "^12.13.0",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "idb-keyval": "^6.2.5",
    "lucide-react": "^0.460.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.6",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "ts-morph": "^28.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.96.0"
  }
}
